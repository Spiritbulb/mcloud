{%- assign eyebrow = section.eyebrow | default: 'Our Mission' -%}
{%- assign settings = store.settings -%}
{%- assign headline = store.name -%}
{%- assign statement = store.description -%}
{%- if settings -%}
  {%- if settings.missionHeadline -%}{%- assign headline = settings.missionHeadline -%}{%- endif -%}
  {%- if settings.mission -%}{%- assign statement = settings.mission -%}{%- endif -%}
{%- endif -%}

<section class="sf-mission relative w-full overflow-hidden py-20 md:py-28">
  <div class="sf-mission-fallback absolute inset-0"></div>
  <div class="relative container mx-auto max-w-4xl px-6 text-center">
    <span class="sf-badge-outline inline-flex items-center border px-2.5 py-0.5 text-xs font-medium mb-4" {% render 'classic/snippets/editable', editing: store.editing, field: 'eyebrow', value: section.eyebrow %}>
      {{ eyebrow }}
    </span>
    <h1 class="sf-heading font-bold tracking-tight" style="font-size: clamp(1.875rem, 5vw, 3rem); line-height: 1.1" {% render 'classic/snippets/editable-setting', editing: store.editing, key: 'missionHeadline', value: settings.missionHeadline %}>
      {{ headline }}
    </h1>
    {%- comment -%}
      Rendered when empty IN THE EDITOR so there is something to click in order to
      write one. A visitor still sees nothing.
    {%- endcomment -%}
    {%- if statement or store.editing -%}
      <p class="font-light mt-4 mx-auto max-w-2xl" style="color: var(--sf-foreground-subtle); font-size: clamp(1rem, 2vw, 1.25rem)" {% render 'classic/snippets/editable-setting', editing: store.editing, key: 'mission', value: settings.mission %}>
        {{ statement }}
      </p>
    {%- endif -%}
  </div>
</section>
