{%- assign settings = store.settings -%}
{%- assign slides = null -%}

{%- if settings -%}
  {%- assign slides = settings.heroSlides -%}
{%- endif -%}

{%- assign has_slides = false -%}
{%- if slides and slides.size > 0 -%}
  {%- assign has_slides = true -%}
{%- endif -%}

{%- unless has_slides -%}
  {%- assign slide_title = store.name -%}
  {%- assign slide_subtitle = store.description -%}
  {%- assign slide_image = null -%}
  {%- assign slide_accent = 'New Arrivals' -%}
  {%- assign slide_btn = 'Shop now' -%}
  {%- if settings -%}
    {%- if settings.heroTitle -%}{%- assign slide_title = settings.heroTitle -%}{%- endif -%}
    {%- if settings.heroSubtitle -%}{%- assign slide_subtitle = settings.heroSubtitle -%}{%- endif -%}
    {%- if settings.heroImage -%}{%- assign slide_image = settings.heroImage -%}{%- endif -%}
    {%- if settings.heroAccent -%}{%- assign slide_accent = settings.heroAccent -%}{%- endif -%}
    {%- if settings.heroButtonText -%}{%- assign slide_btn = settings.heroButtonText -%}{%- endif -%}
  {%- endif -%}
{%- endunless -%}

<section class="sf-hero relative w-full overflow-hidden" style="height: 70vh; min-height: 480px">
  {%- if has_slides -%}
    {{- - MULTI-SLIDE CAROUSEL - -}}
    <div class="sf-hero__track" id="sf-hero-track">
      {%- for slide in slides -%}
        <div
          class="
            sf-hero__slide absolute inset-0 transition-opacity duration-700
            {%- if forloop.first %} opacity-100{% else %} opacity-0 pointer-events-none{% endif %}
          "
          data-index="{{ forloop.index0 }}"
        >
          {%- if slide.image -%}
            <img
              src="{{ slide.image }}"
              alt="{{ slide.title }}"
              class="w-full h-full object-cover"
            >
            <div class="absolute inset-0" style="background: rgba(0,0,0,0.28)"></div>
          {%- else -%}
            <div class="sf-hero-fallback absolute inset-0"></div>
          {%- endif -%}

          <div class="absolute inset-0 flex items-end md:items-center">
            <div
              class="sf-hero__content w-full px-4 pb-16 md:pb-0"
              style="padding-left: clamp(1rem, 5vw, 3rem)"
            >
              <div class="sf-hero-card max-w-xl space-y-4 p-5 sf-hero__card-animate">
                {%- if slide.accent -%}
                  <span class="sf-badge-outline inline-flex items-center border px-2.5 py-0.5 text-xs font-medium">
                    {{ slide.accent }}
                  </span>
                {%- endif -%}
                <h1
                  class="sf-heading font-bold tracking-tight"
                  style="font-size: clamp(1.875rem, 5vw, 3rem); line-height: 1.1"
                >
                  {{ slide.title }}
                </h1>
                {%- if slide.subtitle -%}
                  <p
                    class="font-light"
                    style="color: var(--sf-foreground-subtle); font-size: clamp(0.95rem, 2vw, 1.125rem)"
                  >
                    {{ slide.subtitle }}
                  </p>
                {%- endif -%}
                <a
                  href="#products"
                  class="sf-btn-primary sf-hero__btn inline-flex items-center gap-2 border rounded-none px-6 py-3 text-sm font-medium"
                  onclick="document.getElementById('products')?.scrollIntoView({behavior:'smooth'}); return false;"
                >
                  {{ slide.buttonText | default: 'Shop now' }}
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {{- - DOT INDICATORS - -}}
    <div
      class="absolute bottom-6 flex gap-2 z-30"
      style="left: 50%; transform: translateX(-50%)"
    >
      {%- for slide in slides -%}
        <button
          class="
            sf-hero__dot transition-all duration-300 rounded-none border-0 p-0 cursor-pointer
            {%- if forloop.first %} sf-hero__dot--active{% endif %}
          "
          data-index="{{ forloop.index0 }}"
          aria-label="Go to slide {{ forloop.index }}"
          style="height: 2px; background: {%- if forloop.first %}#fff{%- else %}rgba(255,255,255,0.35){%- endif %}; width: {%- if forloop.first %}3rem{%- else %}1.5rem{%- endif %}"
        ></button>
      {%- endfor -%}
    </div>

  {%- else -%}
    {{- - SINGLE SLIDE - -}}
    {%- if slide_image -%}
      <img
        src="{{ slide_image }}"
        alt="{{ slide_title }}"
        class="w-full h-full object-cover"
      >
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.28)"></div>
    {%- else -%}
      <div class="sf-hero-fallback absolute inset-0"></div>
    {%- endif -%}

    <div class="absolute inset-0 flex items-end md:items-center">
      <div
        class="w-full px-4 pb-16 md:pb-0"
        style="padding-left: clamp(1rem, 5vw, 3rem)"
      >
        <div class="sf-hero-card max-w-xl space-y-4 p-5 sf-hero__card-animate sf-hero__card-animate--load">
          {%- if slide_accent -%}
            <span class="sf-badge-outline inline-flex items-center border px-2.5 py-0.5 text-xs font-medium">
              {{ slide_accent }}
            </span>
          {%- endif -%}
          <h1
            class="sf-heading font-bold tracking-tight"
            style="font-size: clamp(1.875rem, 5vw, 3rem); line-height: 1.1"
          >
            {{ slide_title }}
          </h1>
          {%- if slide_subtitle -%}
            <p class="font-light" style="color: var(--sf-foreground-subtle); font-size: clamp(0.95rem, 2vw, 1.125rem)">
              {{ slide_subtitle }}
            </p>
          {%- endif -%}
          <a
            href="#products"
            class="sf-btn-primary sf-hero__btn inline-flex items-center gap-2 border rounded-none px-6 py-3 text-sm font-medium"
            onclick="document.getElementById('products')?.scrollIntoView({behavior:'smooth'}); return false;"
          >
            {{ slide_btn }}
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  {%- endif -%}
</section>

{%- if has_slides -%}
  <script>
    (function () {
      var slides = document.querySelectorAll('.sf-hero__slide');
      var dots = document.querySelectorAll('.sf-hero__dot');
      if (!slides.length) return;

      var current = 0;

      function goTo(index) {
        slides[current].classList.remove('opacity-100');
        slides[current].classList.add('opacity-0', 'pointer-events-none');
        dots[current].style.width = '1.5rem';
        dots[current].style.background = 'rgba(255,255,255,0.35)';

        current = index;

        slides[current].classList.remove('opacity-0', 'pointer-events-none');
        slides[current].classList.add('opacity-100');
        dots[current].style.width = '3rem';
        dots[current].style.background = '#fff';

        // re-trigger card animation
        var card = slides[current].querySelector('.sf-hero__card-animate');
        if (card) {
          card.classList.remove('sf-hero__card-animate--in');
          void card.offsetWidth; // force reflow
          card.classList.add('sf-hero__card-animate--in');
        }
      }

      dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          goTo(parseInt(this.dataset.index));
          resetTimer();
        });
      });

      // trigger initial animation
      // trigger initial animation on first slide
      var firstCard = slides[0].querySelector('.sf-hero__card-animate');
      if (firstCard) {
        setTimeout(function () {
          firstCard.classList.add('sf-hero__card-animate--in');
        }, 80); // slight delay so transition is visible on first paint
      }

      var timer = setInterval(function () {
        goTo((current + 1) % slides.length);
      }, 5000);

      function resetTimer() {
        clearInterval(timer);
        timer = setInterval(function () {
          goTo((current + 1) % slides.length);
        }, 5000);
      }
    })();
  </script>
{%- endif -%}
