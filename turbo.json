{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "env": [
        "AUTH0_CLIENT_ID",
        "AUTH0_CLIENT_SECRET",
        "AUTH0_DOMAIN",
        "AUTH0_SECRET",
        "DOCS_ADMIN_PASSPHRASE",
        "SUPABASE_SERVICE_ROLE_KEY",
        "NODE_ENV",
        "PAYSTACK_SECRET_KEY",
        "RESEND_API_KEY",
        "TRADING_VERCEL_TOKEN",
        "TRADING_VERCEL_PROJECT_ID",
        "WORKOS_API_KEY",
        "WORKOS_CLIENT_ID",
        "WORKOS_COOKIE_PASSWORD"
      ],
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  }
}
