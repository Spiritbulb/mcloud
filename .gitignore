# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (workspaces hoist to root; also ignore any nested installs)
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# turbo
.turbo/

# testing
coverage/

#docs
docs/

# next.js (any app)
.next/
out/

# cloudflare
.open-next/
.wrangler/
dist-check

# production
build/
**/src/lib/theme-manifest

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.dev.vars

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
.superpowers/
