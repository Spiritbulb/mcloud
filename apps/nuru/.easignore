# Files excluded from the EAS Build upload archive.
# Nuru is a thin client (backend lives in apps/web), so the upload should be
# just source + assets + config. Keep this lean — a bloated archive means slow
# uploads and slow builds.
#
# Works like .gitignore but ONLY for `eas build`. When present, EAS uses this
# instead of .gitignore.
#
# IMPORTANT: no trailing slashes on directory names. EAS's archiver walks the
# tree and tests each entry; a pattern like "node_modules/" matches paths
# *inside* the dir but NOT the dir entry itself, so the walker descends and
# copies it anyway. Bare "node_modules" matches the dir and prunes it. This is
# the difference between a ~1.7 MB upload and a 100 MB one.

# Dependencies (reinstalled on the build server)
node_modules

# Expo / prebuild output — regenerated during the build, never needed in upload
dist
web-build
.expo
.expo-shared

# Generated native projects (managed workflow prebuilds these on the server)
android
ios
.kotlin

# Local build artifacts
*.aab
*.apk
*.keystore
*.jks

# VCS / tooling
.git
*.log
*.tsbuildinfo

# OS cruft
.DS_Store
Thumbs.db
