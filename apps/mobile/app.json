{
  "expo": {
    "name": "Menengai Cloud",
    "slug": "mcloud-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mcloud",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "cloud.menengai.twa"
    },
    "android": {
      "package": "cloud.menengai.twa",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#1c2228",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#1c2228"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "http://192.168.1.68:3000",
      "webBaseUrl": "http://192.168.1.68:3000",
      "workosClientId": "client_01KR36PSYHBHBMG4ED4GSDM6DQ",
      "workosDomain": "https://api.workos.com",
      "router": {},
      "eas": {
        "projectId": "7c75f6a5-e45a-4e0d-bb68-ce44eab0d21c"
      }
    },
    "owner": "thtbshs-team"
  }
}
